{
  "name": "@inkdropapp/remark-gfm-alerts",
  "version": "2.0.9",
  "description": "Inkdrop plugin to render GitHub blockquote-based admonitions",
  "license": "MIT",
  "author": "Keisir",
  "repository": "https://github.com/inkdropapp/gfm-alerts",
  "files": [
    "dist",
    "styles"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./config": {
      "import": "./dist/config.js",
      "types": "./dist/config.d.ts"
    },
    "./styles/index.css": {
      "import": "./styles/index.css",
      "require": "./styles/index.css"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest --run",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm-run-all lint format:check build && npm run test run"
  },
  "dependencies": {
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/unist": "^3.0.3",
    "css-select": "^7.0.0",
    "htmlparser2": "^12.0.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^7.0.2",
    "unified": "^11.0.5",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.15.1"
}
